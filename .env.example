CMF_API_KEY=tu_api_key_cmf
GCP_PROJECT_ID=tu-proyecto-gcp
GCS_BUCKET_NAME=tu-proyecto-gcp-bronze

# Rutas internas del contenedor Airflow.
AIRFLOW_BASE_IMAGE=apache/airflow:2.9.1
AIRFLOW_DOCKER_IMAGE=financial-risk-airflow:2.9.1-dataform
DATAFORM_CLI_VERSION=latest
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/keys/airflow-sa-key.json
DATAFORM_PROJECT_DIR=/opt/airflow/dataform
DATAFORM_RUNTIME_PROJECT_DIR=/tmp/dataform-runtime
DATAFORM_CREDENTIALS_FILE=/tmp/dataform-runtime/.df-credentials.json
PYTHONPATH=/opt/airflow/src

# BigQuery/Dataform.
BQ_RAW_SCHEMA=financial_risk_raw
BQ_SILVER_SCHEMA=financial_risk_silver
BQ_GOLD_SCHEMA=financial_risk_gold
DATAFORM_DEFAULT_DATASET=financial_risk_gold
DATAFORM_DEFAULT_LOCATION=US
DATAFORM_ASSERTION_DATASET=financial_risk_assertions
DATAFORM_CORE_VERSION=3.0.0

# Airflow local.
POSTGRES_IMAGE=postgres:13
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_INTERNAL_WEBSERVER_PORT=8080
AIRFLOW_SCHEDULER_HEALTH_CHECK_PORT=8974
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_FIRSTNAME=Local
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_ROLE=Admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_UID=50000
AIRFLOW_EXECUTOR=LocalExecutor
AIRFLOW_FERNET_KEY=
AIRFLOW_DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW_LOAD_EXAMPLES=false
AIRFLOW_API_AUTH_BACKENDS=airflow.api.auth.backend.basic_auth
AIRFLOW_DAG_OWNER=airflow
AIRFLOW_DAG_START_DATE=2024-01-01T00:00:00
AIRFLOW_DAG_SCHEDULE="0 6 1 * *"
AIRFLOW_DAG_CATCHUP=false
AIRFLOW_DAG_RETRIES=3
AIRFLOW_DAG_RETRY_DELAY_MINUTES=5

# La CMF suele publicar con desfase; el DAG procesa execution_date menos este valor.
CMF_REPORTING_LAG_MONTHS=2
